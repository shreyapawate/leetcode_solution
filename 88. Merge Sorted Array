class Solution {
    public int[] merge(int[] nums1, int m, int[] nums2, int n) {
        int ptr=m+n-1;
        int l=m-1;
        int r=n-1;
        while(l>=0 && r>=0){

            if(nums1[l]>nums2[r]){
                nums1[ptr]=nums1[l];
               
                l--;
                ptr--;
            }else{
                nums1[ptr]=nums2[r];
                
                r--;
                ptr--;
            }
        }
        while(l>=0){
            nums1[ptr]=nums1[l];
            l--;
            ptr--;
        }
        while(r>=0){
            nums1[ptr]=nums2[r];
            r--;
            ptr--;
        }
        return nums1;
        
    }
}
