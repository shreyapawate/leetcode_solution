class Solution {
    public int[] findMissingAndRepeatedValues(int[][] grid) {
        int r=grid.length;
        int c=grid[0].length;
      
        int[]hash= new int[r*c+1];
        for(int i=0;i<r;i++){
            for(int j=0;j<c;j++){
                hash[grid[i][j]]++;
            }
        }
        int[]ans= new int[2];
        for(int i=1;i<=r*c;i++){
            if(hash[i]==2){
                ans[0]=i;
            }
            if(hash[i]==0){
                ans[1]=i;
            }
        }
         return ans;
    }
   
}
